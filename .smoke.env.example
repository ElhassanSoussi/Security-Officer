# ==============================================================================
# .smoke.env.example — Copy to .smoke.env and fill in real values
# ==============================================================================
# ⚠️  NEVER commit .smoke.env with real credentials. It is gitignored.
# Used by E2E test scripts in scripts/*.sh

# Supabase test user credentials (create a dedicated test user)
SMOKE_EMAIL=
SMOKE_PASSWORD=

# Optional: pre-set org ID for smoke tests
SMOKE_ORG_ID=
