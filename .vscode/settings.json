{
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        "./backend",
        "-p",
        "*test.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    "idf.pythonInstallPath": "/usr/bin/python3",
    "workbench.editor.alwaysShowEditorActions": true,
    "workbench.editor.autoLockGroups": {
        "default": true,
        "workbench.editorinputs.searchEditorInput": true,
        "notebookOutputEditor": true,
        "jupyter-notebook": true,
        "dbcode-notebook": true,
        "repl": true,
        "workbench.editors.gettingStartedInput": true,
        "imagePreview.previewEditor": true,
        "ijnb-notebook": true,
        "vscode.audioPreview": true,
        "vscode.videoPreview": true,
        "jsProfileVisualizer.cpuprofile.table": true,
        "jsProfileVisualizer.heapsnapshot.table": true,
        "phpprofiler.cachegrind": true,
        "mssql.executionPlanView": true,
        "gitlens.rebase": true,
        "chatgpt.conversationEditor": true,
        "workbench.input.interactive": true,
        "mainThreadWebview-markdown.preview": true
    },
    "chatgpt.openOnStartup": true,
    "geminicodeassist.agentDebugMode": true,
    "geminicodeassist.agentYoloMode": true,
    "geminicodeassist.codeGenerationPaneViewEnabled": true,
    "geminicodeassist.inlineSuggestions.nextEditPredictions": true,
    "geminicodeassist.outlines.automaticOutlineGeneration": true,
    "github.copilot.chat.codeGeneration.instructions": [
        
    ],
    "python.analysis.extraPaths": [
        "backend/venv/lib/python3.11/site-packages"
    ],
    "python.defaultInterpreterPath": "backend/venv/bin/python",
    "files.associations": {
        "**/backend/**/*.sql": "postgres"
    },
    "mssql.intelliSense.enableIntelliSense": false,
    "mssql.intelliSense.enableSuggestions": false,
    "mssql.intelliSense.enableQuickInfo": false,
    "mssql.intelliSense.enableErrorChecking": false,
    "[sql]": {
        "editor.defaultFormatter": null
    },
    "docker.lsp.experimental.vulnerabilityScanning": false,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false,
        "sql": true,
        "javascript": true,
        "typescript": true,
        "python": true,
        "json": true,
        "yaml ": true,
        "typescriptreact": true,
        "javascriptreact ": true,
        "dockerfile": true,
        "shellscript": true,
        "prisma": true,
        "dotenv": true
    },
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.agent.thinkingTool": true,
    "github.copilot.chat.completionContext.typescript.mode": "on",
    "github.copilot.chat.editor.temporalContext.enabled": true,
    "github.copilot.chat.edits.temporalContext.enabled": true,
    "github.copilot.chat.generateTests.codeLens": true,
    "github.copilot.chat.languageContext.fix.typescript.enabled": true,
    "github.copilot.chat.languageContext.inline.typescript.enabled": true,
    "github.copilot.chat.languageContext.typescript.enabled": true,
    "github.copilot.chat.search.keywordSuggestions": true,
    "editor.defaultFormatter": "Sixth.sixth-ai",
    "githubPullRequests.experimental.chat": true,
    "githubPullRequests.experimental.useQuickChat": true
}