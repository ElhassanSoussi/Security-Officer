# ==============================================================================
# frontend/.env.local.example — Copy to .env.local and fill in real values
# ==============================================================================
# ⚠️  NEVER commit .env.local with real credentials. Only this template is tracked.
# See also: frontend/.env.example (canonical template)

# ── Supabase (Project Settings → API) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── API Routing ───────────────────────────────────────────────────────────────
# Local dev: /api/v1 | Production: https://api.nyccompliancearchitect.com/api/v1
NEXT_PUBLIC_API_URL=/api/v1
# Local dev: http://localhost:8000 | Production: your Render internal URL
BACKEND_INTERNAL_URL=http://localhost:8000

# ── Stripe (publishable key only — NEVER put secret key here) ─────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001

