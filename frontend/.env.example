# ==============================================================================
# frontend/.env.example — Copy to .env.local and fill in real values
# ==============================================================================
# ⚠️  NEVER commit .env.local with real credentials. Only .env.example is tracked.
# ==============================================================================
# Next.js requires NEXT_PUBLIC_ prefix for client-side env vars.

# ── Supabase (Project Settings → API) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── API Routing ───────────────────────────────────────────────────────────────
# Local dev: /api/v1 (Next.js proxy handles forwarding to backend)
# Production (Vercel): https://api.nyccompliancearchitect.com/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# ── Backend Internal URL (server-side only, for Next.js API route proxying) ──
# Local dev: http://localhost:8000
# Production (Vercel): https://nyc-compliance-api.onrender.com (your Render URL)
BACKEND_INTERNAL_URL=http://localhost:8000

# ── Optional ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:3001
