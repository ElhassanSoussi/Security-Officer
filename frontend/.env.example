# ==============================================================================
# frontend/.env.example — Copy to .env.local and fill in real values
# ==============================================================================
# ⚠️  NEVER commit .env.local with real credentials. Only .env.example is tracked.
# ==============================================================================
# Next.js requires NEXT_PUBLIC_ prefix for client-side env vars.

# ── Supabase (Project Settings → API) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── API Routing ───────────────────────────────────────────────────────────────
# LOCAL DEV: leave as /api/v1 (Next.js proxy forwards to BACKEND_INTERNAL_URL)
# PRODUCTION (Vercel): leave as /api/v1 and set BACKEND_INTERNAL_URL below.
#   Alternatively, set to the full backend URL:
#     https://security-officer.onrender.com/api/v1
#   (The /api/v1 suffix is REQUIRED — without it, requests return 404.)
NEXT_PUBLIC_API_URL=/api/v1

# ── Backend Internal URL (server-side only, for Next.js API route proxying) ──
# LOCAL DEV: http://localhost:8000
# PRODUCTION (Vercel): Your Render backend URL (NO /api/v1 suffix here — the
#   proxy appends it automatically).
#   Example: https://security-officer.onrender.com
BACKEND_INTERNAL_URL=http://localhost:8000

# ── Stripe (publishable key only — NEVER put secret key here) ─────────────────
# Get from Stripe Dashboard → Developers → API keys → Publishable key
# ⚠️  Only NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is allowed in the frontend.
#     STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET must ONLY be set on the backend.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── Vercel Deployment Protection Bypass (optional, Preview only) ──────────────
# If Deployment Protection blocks /api/v1/* on Preview deployments, generate a
# bypass secret in Vercel → Settings → Deployment Protection → Protection
# Bypass for Automation, and set it here. Not needed for Production deployments.
# VERCEL_AUTOMATION_BYPASS_SECRET=
