# ==============================================================================
# backend/.env.example — Copy to .env and fill in real values
# ==============================================================================
# ⚠️  NEVER commit .env with real credentials. Only .env.example is tracked.
# ==============================================================================

# ── Supabase (required) ───────────────────────────────────────────────────────
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=                        # https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # eyJ... (service_role key — required)
SUPABASE_JWT_SECRET=                 # JWT secret (Settings → API → JWT Secret)
# Optional aliases (auto-resolved — you only need ONE service key):
#   SUPABASE_SECRET_KEY  →  falls back to SUPABASE_SERVICE_ROLE_KEY
#   SUPABASE_KEY         →  anon key; falls back to service-role key if unset
SUPABASE_KEY=
SUPABASE_SECRET_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Stripe (optional — only required when BILLING_ENABLED=true) ───────────────
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Plans page plan Price IDs (Starter/Growth/Elite)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ELITE=
# Plan Price IDs (FREE/PRO/ENTERPRISE)
STRIPE_PRICE_FREE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_TRIAL_DAYS=14

# ── Sentry (optional — error monitoring) ──────────────────────────────────────
SENTRY_DSN=

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
PROJECT_NAME=NYC Compliance Architect
API_V1_STR=/api/v1

# ── CORS (required in production — comma-separated origins) ───────────────────
# Local: http://localhost:3000,http://localhost:3001
# Production: https://nyccompliancearchitect.com,https://www.nyccompliancearchitect.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend URL (for backend email links, Stripe redirects) ─────────────────
# Local: http://localhost:3001
# Production: https://nyccompliancearchitect.com
FRONTEND_URL=http://localhost:3001

# ── Upload / Rate Limits ──────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_CONTACT=5
RATE_LIMIT_AUTH=20
RATE_LIMIT_ANALYSIS=5
RATE_LIMIT_EXPORT=10
